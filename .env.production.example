# Copy to .env on your VPS or paste into Render/Vercel env dashboards.
# Run: powershell -File scripts/generate-secrets.ps1

# --- Public URLs (use https in production) ---
NEXT_PUBLIC_API_URL=https://api.YOUR_DOMAIN.com
FASTAPI_URL=https://api.YOUR_DOMAIN.com
NEXT_API_URL=https://app.YOUR_DOMAIN.com
CORS_ORIGINS=https://app.YOUR_DOMAIN.com

# --- Database (Neon / Supabase / Render Postgres / self-hosted) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/slideflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=slideflow

# --- Redis (Upstash / Render Redis / self-hosted) ---
REDIS_URL=redis://default:PASSWORD@HOST:6379/0
REDIS_PUBSUB_CHANNEL=presentation_events

# --- Service auth (same value everywhere) ---
INTERNAL_SERVICE_TOKEN=
INTERNAL_SIGNING_SECRET=
WS_HEARTBEAT_SECONDS=30

# --- Clerk (live keys + add domains in Clerk dashboard) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# --- Uploads & AI ---
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=
OPENAI_API_KEY=sk-...
